  "exports": "./src/mod.ts",
  "nodeModulesDir": "auto",
  "imports": {
    "viem": "npm:viem@2.47.6",
    "protobufjs": "npm:protobufjs@7.5.4",
    "@noble/hashes/blake3": "npm:@noble/hashes@1.8.0/blake3",
